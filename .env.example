# CEF experiment API keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# OpenRouter (unified API for GPT-4o, o3-mini, Claude, DeepSeek)
# Get key at: https://openrouter.ai/settings/keys
# Charge $10 at: https://openrouter.ai/settings/credits
OPENROUTER_API_KEY=sk-or-v1-...

# Google AI Studio (free tier, for Gemini 1.5 Pro/Flash)
# Get key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# Optional: direct provider keys (not needed if using OpenRouter)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# TOGETHER_API_KEY=...
